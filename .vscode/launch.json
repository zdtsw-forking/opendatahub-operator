    "version": "0.2.0",
    "configurations": [
        {
            "name": "Connect to OCP",
            "type": "go",
            "request": "attach",
            "mode": "remote",
            "remotePath": "/manager",
            "port": 40000,
            "host": "127.0.0.1"
        },
        {
            "name": "Launch file",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "env": {
                "DEFAULT_MANIFESTS_PATH": "//home/wenzhou/test/wen/opendatahub-operator/opt/manifests",
                "DISABLE_DSC_CONFIG": "false",
                "OPERATOR_NAMESPACE": "openshift-operators"
            },
            "program": "main.go"
        },
        {
            "name": "Launch Package",
            "type": "go",
            "request": "launch",
            "mode": "exec",
            "env": {
                "DEFAULT_MANIFESTS_PATH": "/home/wenzhou/test/wen/opendatahub-operator/opt/manifests",
                "DISABLE_DSC_CONFIG": "false",
                "OPERATOR_NAMESPACE": "openshift-operators"
            },
            "program": "/home/wenzhou/test/wen/opendatahub-operator/bin/manager"
        },
    ]
}