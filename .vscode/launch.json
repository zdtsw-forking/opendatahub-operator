{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Connect to OCP",
            "type": "go",
            "request": "attach",
            "mode": "remote",
            "remotePath": "/manager",
            "port": 40000,
            "host": "127.0.0.1"
        },
        {
            "name": "Launch file",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "env": {
                "DEFAULT_MANIFESTS_PATH": "/home/wenzhou/test/wen/opendatahub-operator/opt/manifests",
                "DISABLE_DSC_CONFIG": "false",
                "OPERATOR_NAMESPACE": "openshift-operators",
                "ODH_PLATFORM_TYPE": "OpenDataHub",
            },
            "program": "main.go"
        },
        {
            "name": "Launch Package",
            "type": "go",
            "request": "launch",
            "mode": "exec",
            "env": {
                "DEFAULT_MANIFESTS_PATH": "./opt/manifests",
                "DISABLE_DSC_CONFIG": "false",
                "OPERATOR_NAMESPACE": "openshift-operators",
                "ODH_PLATFORM_TYPE": "OpenDataHub",
            },
            "program": "/home/wenzhou/test/wen/opendatahub-operator/bin/manager"
        },
        { 
            "name": "Debug Operator without Webhook",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "main.go",
            "buildFlags": [
                "-tags", "nowebhook"
            ],
            "env": {
                "OPERATOR_NAMESPACE": "openshift-operators",
                "DISABLE_DSC_CONFIG": "true",
                "DEFAULT_MANIFESTS_PATH": "./opt/manifests",
                "ODH_PLATFORM_TYPE": "OpenDataHub",
            },
            "args": [
                "--log-mode=devel"
            ],
            "cwd": "${workspaceFolder}",
        }
    ]
}